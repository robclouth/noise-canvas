{
  "name": "noise-canvas",
  "version": "0.1.17",
  "productName": "Noise Canvas",
  "description": "Photoshop for sound",
  "main": "./out/main/index.js",
  "author": "Rob Clouth",
  "homepage": "https://github.com/robclouth/noise-canvas",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:ext": "vite --config vite.extension.config.ts",
    "build:ext": "vite build --config vite.extension.config.ts",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "bash scripts/fetch-link.sh && bash scripts/fetch-onnx.sh && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir --publish=never",
    "build:win": "npm run build && electron-builder --win --publish=never",
    "build:mac": "electron-vite build && dotenv -e .env -- electron-builder --mac --publish=never",
    "build:mac:x64": "electron-vite build && dotenv -e .env -- electron-builder --mac --x64 --publish=never",
    "build:mac:arm64": "electron-vite build && dotenv -e .env -- electron-builder --mac --arm64 --publish=never",
    "build:linux": "electron-vite build && electron-builder --linux --publish=never",
    "version": "git add -A",
    "postversion": "git push && git push --tags",
    "release:patch": "npm version patch -m 'Release v%s'",
    "release:minor": "npm version minor -m 'Release v%s'",
    "release:major": "npm version major -m 'Release v%s'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "ffmpeg-static": "^5.2.0",
    "onnxruntime-node": "^1.24.3",
    "simplex-noise": "^4.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^8.3.5",
    "@mantine/hooks": "^8.3.5",
    "@mantine/modals": "^8.3.5",
    "@mantine/notifications": "^8.3.5",
    "@react-three/drei": "^10.7.5",
    "@react-three/fiber": "^9.3.0",
    "@stdlib/string-truncate-middle": "^0.2.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.7.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^10.0.0",
    "electron": "^37.2.3",
    "electron-builder": "26.0.19",
    "electron-devtools-installer": "^4.0.0",
    "electron-updater": "^6.3.9",
    "electron-vite": "^4.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "immer": "^10.1.3",
    "jsfive": "^0.4.0",
    "lint-staged": "^16.4.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.542.0",
    "lygia": "^1.3.3",
    "nan": "^2.23.0",
    "next-themes": "^0.4.6",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.4.2",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-resizable-panels": "^3.0.5",
    "sonner": "^2.0.7",
    "three": "^0.179.1",
    "tonal": "^6.4.2",
    "tone": "^15.1.22",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vite-plugin-glsl": "^1.5.1",
    "vitest": "^4.0.18",
    "zod": "^4.1.12"
  }
}
